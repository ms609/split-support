begin mrbayes;
  
  set autoclose=yes nowarnings=yes;
  lset coding=variable rates=gamma ngammacat=6;
  
  prset statefreqpr=fixed(equal); [Jukes-Cantor model]
  prset brlenspr=unconstrained:uniform(0,0.245568); [length * rate = 0.245568]
  prset tratiopr=fixed(1);
  
  mcmcp nruns=2 nchains=8 samplefreq=100 burninfrac=0.5;
  mcmcp checkpoint=no;
  mcmcp printfreq=25000 diagnfreq=50000 printmax=4;
  mcmcp ngen=5000000 stoprule=yes stopval=0.007;
  
  mcmc;
  sump;
  sumt minpartfreq=0.1;
  
  quit;
  
end;
